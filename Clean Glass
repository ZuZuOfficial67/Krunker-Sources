@import url('https://fonts.googleapis.com/css2?family=DynaPuff:wght@400..700&family=Pacifico&display=swap');

:root {
    /* 18 Character Max */
    --Name: "notKaZu";
    --Name2: "notKaZu";
    --Clan:" {KPD}";
    --color: #ff9a00;
    --uiscale: 6;
    --div-grey: rgba(0, 0, 0, 0);
    --div-black: rgba(0, 0, 0, 0);
    --accent-color: #0af;
    --accent2-color: rgb(0 0 0 / 60%);
    --friendly-color: #0af;
    --enemy-color: red;
}

/* Custom font fallback */
@font-face {
    font-family: gamefont;
    src: url(https://fonts.gstatic.com/s/montserrat/v15/JTURjIg1_i6t8kCHKm45_dJE3gnD_g.woff2);
}

/* Apply DynaPuff to all text except icons */
*:not(.material-icons):not(.material-icons-outlined):not(.menBtnIcn) {
    font-family: 'DynaPuff', cursive !important;
}

/* RGB Animation */
@keyframes rgbText {
    0% {
        color: #ff0000;
    }
    16% {
        color: #ff8800;
    }
    33% {
        color: #ffff00;
    }
    50% {
        color: #00ff00;
    }
    66% {
        color: #0088ff;
    }
    83% {
        color: #aa00ff;
    }
    100% {
        color: #ff0000;
    }
}

