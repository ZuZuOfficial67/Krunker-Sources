/* ===== AMMO ===== */
#ammoVal {
    position: absolute !important;
    top: calc(50% + 440px) !important;
    right: -105px !important;

    font-size: 46px !important;
    color: #0af !important;
    text-shadow: none !important;

    transform: none !important;
    letter-spacing: 2px !important;
}

/* ===== RELOAD BAR - pakai ammoHolder karena game animasikan background-size-nya ===== */
#ammoHolder {
    position: fixed !important;
    left: 50% !important;
    top: calc(50% + 25px) !important;
    bottom: unset !important;
    transform: translateX(-50%) !important;
    width: 50px !important;
    height: 6px !important;
    border-radius: 3px !important;
    background-color: rgba(255, 255, 255, 0) !important;
    background-image: linear-gradient(to right, #0af, #0af) !important;
    background-repeat: no-repeat !important;
    background-position: left center !important;
    display: block !important;
    font-size: 0 !important;
    letter-spacing: 0 !important;
    skewX: none !important;
}

/* Teks ! Reloading ! di bawah bar */
#reloadMsg {
    position: fixed !important;
    left: 50% !important;
    top: calc(50% + 62px) !important;
    bottom: unset !important;
    transform: translateX(-50%) !important;
    background-color: transparent !important;
    border: none !important;
    font-size: 0 !important;
    width: 160px !important;
    height: auto !important;
    padding: 0 !important;
    line-height: normal !important;
    color: transparent !important;
    overflow: visible !important;
}

#reloadMsg::after {
    content: '! Reloading !' !important;
    display: block !important;
    font-size: 20px !important;
    color: #0af !important;
    text-align: center !important;
    margin-top: 6px !important;
    text-shadow: 0 0 10px #0af !important;
    white-space: nowrap !important;
    letter-spacing: 2px !important;
}

#ammoVal span:not(:first-child) {
    display: none !important;
}
#ammoVal > span:nth-child(n + 2) {
    display: none !important;
}
#ammoMax,
#ammoIcon,
#ammoValSub {
    display: none !important;
}

