// ==UserScript==
// @name         CUSTOM SKY
// @version      2.0
// @description  custom map properties swapper (optimized)
// @author       notJustKaZu
// @match        https://krunker.io/*
// @icon         https://www.google.com/s2/favicons?sz=64&domain=krunker.io
// @run-at       document-start
// @grant        unsafeWindow
// ==/UserScript==

const log = console.log;
const i = (typeof unsafeWindow !== 'undefined') ? unsafeWindow : window;
const global = i;

const origFetch = global.fetch;
const origDigest = global.crypto.subtle.digest.bind(global.crypto.subtle);

// ✅ FIX 1: Singleton decoder — jangan bikin TextDecoder baru tiap panggilan digest
const decoder = new TextDecoder();
const encoder = new TextEncoder();

global.curMap = null;
let lastMapDigest = null;

let lighting = {
    "ambientI": 0.5,
    "lightI": 0,
    "sky": "rgb(0, 0, 0)",
};

let defaultSettings = {
    "skyDome": false,
    "shadowD": 0,
    "ambient": 13363199,
    "light": 5723991,
    "lightD": 310,
    "correctLights": false,
    "toneMappingExposure": 0,
    "outputEncoding": "0",
};

// ✅ FIX 2: Cache overrides — jangan spread tiap kali customFetch jalan
const overrides = { ...defaultSettings, ...lighting };

Object.defineProperty(global.crypto.subtle, "digest", {
    get: () => {
        return (...args) => {
            // ✅ FIX 3: Early exit — skip proses berat kalau data kosong atau kecil banget
            const buf = args[1];
            if (!buf || buf.byteLength < 30) {
                return origDigest(...args);
            }

            // ✅ FIX 4: Cek byte pertama langsung (0x7B = '{') sebelum decode penuh
            const firstByte = new Uint8Array(buf)[0];
            if (firstByte !== 0x7B) {
                return origDigest(...args);
            }

            // ✅ FIX 5: Cek lastMapDigest tersedia sebelum decode & parse
            if (!lastMapDigest) {
                return origDigest(...args);
            }

            try {
                const text = decoder.decode(buf);
                // ✅ FIX 6: Cek string punya "name" dan "objects" dulu sebelum JSON.parse penuh
                if (!text.includes('"name"') || !text.includes('"objects"')) {
                    return origDigest(...args);
                }
                const obj = JSON.parse(text);
                if (obj?.name && obj?.objects) {
                    return lastMapDigest;
                }
            } catch {
                // silent — bukan map data
            }

            return origDigest(...args);
        };
    }
});

global.fetch = (...args) => {
    if (args && typeof args[0] === "string") {
        if (args[0].includes("/report/error")) return;
        if (args[0].includes("io/maps/")) {
            log('map grabbed (window.curMap)');
            return customFetch(...args);
        }
    }
    return origFetch(...args);
};

async function customFetch(...args) {
    const response = await origFetch(...args);

    const transformer = new TransformStream({
        async transform(chunk, controller) {
            try {
                const text = decoder.decode(chunk);
                const parsed = JSON.parse(text);
                const modObj = parsed.data;

                global.curMap = modObj;

                // ✅ FIX 7: Hitung digest dari data ASLI sebelum di-modify
                const origData = JSON.stringify(modObj);
                lastMapDigest = await origDigest("SHA-256", encoder.encode(origData));

                // ✅ FIX 8: Pakai cached overrides, bukan spread tiap kali
                Object.assign(modObj, overrides);

                controller.enqueue(
                    encoder.encode(JSON.stringify({ data: modObj }))
                );
            } catch (err) {
                log("customFetch transform error:", err);
                // ✅ FIX 9: Fallback — kalau gagal, pass chunk asli biar game ga crash
                controller.enqueue(chunk);
            }
        }
    });

    return new Response(
        response.body.pipeThrough(transformer),
        response
    );
}
